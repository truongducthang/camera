# RTSP URL của camera. Stream chính, ví dụ Hikvision:
#   rtsp://admin:pass@192.168.1.10:554/Streaming/Channels/101
# Hoặc Dahua:
#   rtsp://admin:pass@192.168.1.10:554/cam/realmonitor?channel=1&subtype=0
FRIGATE_CAM01_URL=rtsp://admin:PASSWORD@192.168.1.5:554/ch1/sub

# Mật khẩu cho Frigate RTSP restream (đặt gì cũng được, chỉ dùng nội bộ)
FRIGATE_RTSP_PASSWORD=changeme

# Telegram bot:
# 1. Chat với @BotFather trên Telegram, gõ /newbot, làm theo hướng dẫn → token
# 2. Lấy chat_id: chat với @userinfobot, hoặc gửi tin nhắn cho bot rồi vào
#    https://api.telegram.org/bot<TOKEN>/getUpdates xem field "chat":{"id":...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
